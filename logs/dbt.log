[0m19:47:54.536006 [debug] [Thread-1 (]: On model.pharma_pipeline.mart_sales_by_territory: /* {"app": "dbt", "dbt_version": "1.11.11", "profile_name": "pharma_pipeline", "target_name": "dev", "node_id": "model.pharma_pipeline.mart_sales_by_territory"} */

  
    
    

    create  table
      "dev"."main"."mart_sales_by_territory__dbt_tmp"
  
    as (
      with base as (
    select * from "dev"."main"."int_sales_incremental"
),

final as (
    select
        territory,
        product,
        week,
        weekly_units,
        weekly_revenue_usd,

        -- Cumuls reconstruits
        sum(weekly_units) over (
            partition by territory, product
            order by week
        ) as running_units,

        sum(weekly_revenue_usd) over (
            partition by territory, product
            order by week
        ) as running_revenue_usd,

        -- Part de chaque territoire par semaine
        round(
            100.0 * weekly_revenue_usd / nullif(
                sum(weekly_revenue_usd) over (partition by week, product), 0
            ), 2
        ) as territory_revenue_share_pct

    from base
)

select * from final
order by product, territory, week
    );
  
  
