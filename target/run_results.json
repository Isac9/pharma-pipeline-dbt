{"metadata": {"dbt_schema_version": "https://schemas.getdbt.com/dbt/run-results/v6.json", "dbt_version": "1.11.11", "generated_at": "2026-06-24T07:30:11.608412Z", "invocation_id": "3ac8f17f-8cb8-4965-8187-06c23f464b94", "invocation_started_at": "2026-06-24T07:30:06.504932Z", "env": {}}, "results": [{"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-24T07:30:11.515473Z", "completed_at": "2026-06-24T07:30:11.519447Z"}, {"name": "execute", "started_at": "2026-06-24T07:30:11.519733Z", "completed_at": "2026-06-24T07:30:11.519743Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.004942893981933594, "adapter_response": {}, "message": null, "failures": null, "unique_id": "seed.pharma_pipeline.raw_sales", "compiled": null, "compiled_code": null, "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-24T07:30:11.521550Z", "completed_at": "2026-06-24T07:30:11.524432Z"}, {"name": "execute", "started_at": "2026-06-24T07:30:11.524794Z", "completed_at": "2026-06-24T07:30:11.524802Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.003857135772705078, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.pharma_pipeline.stg_sales", "compiled": true, "compiled_code": "with source as (\n    select * from \"dev\".\"main\".\"raw_sales\"\n),\n\ncleaned as (\n    select\n        week,\n        territory,\n        product,\n        cumulative_units,\n        cumulative_revenue_usd,\n        current_timestamp as loaded_at\n    from source\n    where territory is not null\n      and product is not null\n      and cumulative_units >= 0\n      and cumulative_revenue_usd >= 0\n)\n\nselect * from cleaned", "relation_name": "\"dev\".\"main\".\"stg_sales\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-24T07:30:11.526433Z", "completed_at": "2026-06-24T07:30:11.528990Z"}, {"name": "execute", "started_at": "2026-06-24T07:30:11.529395Z", "completed_at": "2026-06-24T07:30:11.529401Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.0035467147827148438, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.pharma_pipeline.int_sales_incremental", "compiled": true, "compiled_code": "with base as (\n    select * from \"dev\".\"main\".\"stg_sales\"\n),\n\nincremental as (\n    select\n        week,\n        territory,\n        product,\n        cumulative_units,\n        cumulative_revenue_usd,\n\n        -- Logique Week N = Cumul N - Cumul N-1\n        cumulative_units - lag(cumulative_units, 1, 0) over (\n            partition by territory, product\n            order by week\n        ) as weekly_units,\n\n        cumulative_revenue_usd - lag(cumulative_revenue_usd, 1, 0) over (\n            partition by territory, product\n            order by week\n        ) as weekly_revenue_usd\n\n    from base\n)\n\nselect * from incremental\nwhere weekly_units >= 0", "relation_name": "\"dev\".\"main\".\"int_sales_incremental\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-24T07:30:11.531081Z", "completed_at": "2026-06-24T07:30:11.541356Z"}, {"name": "execute", "started_at": "2026-06-24T07:30:11.541736Z", "completed_at": "2026-06-24T07:30:11.541743Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.011350631713867188, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.pharma_pipeline.accepted_values_stg_sales_product__DrugA__DrugB.18b50f6063", "compiled": true, "compiled_code": "\n    \n    \n\nwith all_values as (\n\n    select\n        product as value_field,\n        count(*) as n_records\n\n    from \"dev\".\"main\".\"stg_sales\"\n    group by product\n\n)\n\nselect *\nfrom all_values\nwhere value_field not in (\n    'DrugA','DrugB'\n)\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-24T07:30:11.543085Z", "completed_at": "2026-06-24T07:30:11.551611Z"}, {"name": "execute", "started_at": "2026-06-24T07:30:11.552056Z", "completed_at": "2026-06-24T07:30:11.552063Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.009627103805541992, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.pharma_pipeline.not_null_stg_sales_cumulative_units.19722fef00", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect cumulative_units\nfrom \"dev\".\"main\".\"stg_sales\"\nwhere cumulative_units is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-24T07:30:11.553319Z", "completed_at": "2026-06-24T07:30:11.558022Z"}, {"name": "execute", "started_at": "2026-06-24T07:30:11.558480Z", "completed_at": "2026-06-24T07:30:11.558487Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.005746364593505859, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.pharma_pipeline.not_null_stg_sales_product.490368e704", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect product\nfrom \"dev\".\"main\".\"stg_sales\"\nwhere product is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-24T07:30:11.559717Z", "completed_at": "2026-06-24T07:30:11.564035Z"}, {"name": "execute", "started_at": "2026-06-24T07:30:11.564423Z", "completed_at": "2026-06-24T07:30:11.564430Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.005300760269165039, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.pharma_pipeline.not_null_stg_sales_territory.72f0b13561", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect territory\nfrom \"dev\".\"main\".\"stg_sales\"\nwhere territory is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-24T07:30:11.565649Z", "completed_at": "2026-06-24T07:30:11.571214Z"}, {"name": "execute", "started_at": "2026-06-24T07:30:11.571601Z", "completed_at": "2026-06-24T07:30:11.571608Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.00651860237121582, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.pharma_pipeline.not_null_stg_sales_week.3e4b7d01ca", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect week\nfrom \"dev\".\"main\".\"stg_sales\"\nwhere week is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-24T07:30:11.572803Z", "completed_at": "2026-06-24T07:30:11.574968Z"}, {"name": "execute", "started_at": "2026-06-24T07:30:11.575408Z", "completed_at": "2026-06-24T07:30:11.575428Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.0032181739807128906, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.pharma_pipeline.mart_sales_by_territory", "compiled": true, "compiled_code": "with base as (\n    select * from \"dev\".\"main\".\"int_sales_incremental\"\n),\n\nfinal as (\n    select\n        territory,\n        product,\n        week,\n        weekly_units,\n        weekly_revenue_usd,\n\n        -- Cumuls reconstruits\n        sum(weekly_units) over (\n            partition by territory, product\n            order by week\n        ) as running_units,\n\n        sum(weekly_revenue_usd) over (\n            partition by territory, product\n            order by week\n        ) as running_revenue_usd,\n\n        -- Part de chaque territoire par semaine\n        round(\n            100.0 * weekly_revenue_usd / nullif(\n                sum(weekly_revenue_usd) over (partition by week, product), 0\n            ), 2\n        ) as territory_revenue_share_pct\n\n    from base\n)\n\nselect * from final\norder by product, territory, week", "relation_name": "\"dev\".\"main\".\"mart_sales_by_territory\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-24T07:30:11.577222Z", "completed_at": "2026-06-24T07:30:11.581883Z"}, {"name": "execute", "started_at": "2026-06-24T07:30:11.582285Z", "completed_at": "2026-06-24T07:30:11.582300Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.0058917999267578125, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.pharma_pipeline.not_null_int_sales_incremental_weekly_units.795ff9b278", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect weekly_units\nfrom \"dev\".\"main\".\"int_sales_incremental\"\nwhere weekly_units is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-24T07:30:11.583555Z", "completed_at": "2026-06-24T07:30:11.604674Z"}, {"name": "execute", "started_at": "2026-06-24T07:30:11.605069Z", "completed_at": "2026-06-24T07:30:11.605075Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.022113323211669922, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.pharma_pipeline.not_null_mart_sales_by_territory_territory_revenue_share_pct.ab0dd3cbd7", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect territory_revenue_share_pct\nfrom \"dev\".\"main\".\"mart_sales_by_territory\"\nwhere territory_revenue_share_pct is null\n\n\n", "relation_name": null, "batch_results": null}], "elapsed_time": 2.7273433208465576, "args": {"skip_nodes_if_on_run_start_fails": false, "require_ref_searches_node_package_before_root": false, "state_modified_compare_vars": false, "source_freshness_run_project_hooks": true, "log_format_file": "debug", "which": "generate", "exclude": [], "compile": true, "static_parser": true, "upload_to_artifacts_ingest_api": false, "log_file_max_bytes": 10485760, "log_format": "default", "require_generic_test_arguments_property": true, "show_all_deprecations": false, "use_fast_test_edges": false, "invocation_co